<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="clr-namespace:SmartCash.ViewModels.Transacoes"
             xmlns:models="clr-namespace:SmartCash.EfCore.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:DataType="vm:TransacaoDetalhesViewModel"
             Background="{DynamicResource WaBackground}"
             x:Class="SmartCash.Views.Transacoes.TransacaoDetalhesView">

	<Grid RowDefinitions="Auto, *">

		<Border Grid.Row="0" Classes="HeaderBox" CornerRadius="0"
                x:CompileBindings="False"
                Padding="{Binding $parent[TopLevel].InsetsManager.SafeAreaPadding, FallbackValue='0,40,0,0'}">

			<Border Classes="HeaderContent" Padding="10,12">
				<StackPanel Spacing="15">
					<Grid ColumnDefinitions="Auto, *, Auto">

						<Button Grid.Column="0"
                                Command="{Binding VoltarCommand}"
                                Classes="IconButton"
                                Margin="0,0,5,0">
							<i:Icon Value="fa-solid fa-arrow-left" Foreground="{DynamicResource WaHeaderIcon}" FontSize="24"/>
						</Button>

						<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
							<Border Classes="IconAvatarCard">
								<i:Icon Value="fa-solid fa-receipt" Classes="IconAvatarGraphic"/>
							</Border>
							<TextBlock Text="Detalhes" Classes="HeaderTitle" VerticalAlignment="Center"/>
						</StackPanel>

						<Rectangle Grid.Column="2" Width="32" Fill="Transparent"/>
					</Grid>

					<StackPanel IsVisible="{Binding !EstaCarregando}" HorizontalAlignment="Center" Spacing="5">
						<TextBlock Text="{Binding Transacao.ValorTotal, StringFormat='{}{0:C}'}" Classes="HeaderSummaryValue"/>
						<TextBlock Text="{Binding Transacao.Data, StringFormat='{}{0:dd/MM/yyyy}'}" Classes="HeaderSummarySubtitle"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<Grid Grid.Row="1">

			<ProgressBar IsIndeterminate="True" IsVisible="{Binding EstaCarregando}" Classes="LoadingBar"/>

			<ScrollViewer IsVisible="{Binding !EstaCarregando}">
				<StackPanel Classes="ListArea">

					<Border Classes="ListContainerCard">
						<ListBox ItemsSource="{Binding ItensDoDia}"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="vm:ItemDisplayModel">
									<Border Classes="ListItemBorder">

										<Border.ContextFlyout>
											<MenuFlyout>
												<MenuItem Header="Alterar Data"
                                                          x:CompileBindings="False"
                                                          Command="{Binding $parent[UserControl].DataContext.AbrirEdicaoDataCommand}"
                                                          CommandParameter="{Binding}">
													<MenuItem.Icon>
														<i:Icon Value="fa-regular fa-calendar-days"/>
													</MenuItem.Icon>
												</MenuItem>
												<MenuItem Header="Excluir Ítem"
                                                          x:CompileBindings="False"
                                                          Command="{Binding $parent[UserControl].DataContext.ExcluirItemCommand}"
                                                          CommandParameter="{Binding}">
													<MenuItem.Icon>
														<i:Icon Value="fa-solid fa-trash-can" Classes="IconDanger"/>
													</MenuItem.Icon>
												</MenuItem>
											</MenuFlyout>
										</Border.ContextFlyout>

										<Grid ColumnDefinitions="Auto, *, Auto">

											<Border Grid.Column="0" Classes="IconAvatarCard">
												<i:Icon Value="{Binding Item.Produto.Categoria.IconeApresentacao}" Classes="IconAvatarGraphic"/>
											</Border>

											<StackPanel Grid.Column="1" Classes="ListItemTextContainer">
												<TextBlock Text="{Binding Item.Produto.Nome}" Classes="ListItemTitle"/>

												<StackPanel Orientation="Horizontal" Spacing="5">
													<TextBlock Text="{Binding Horario, StringFormat='{}{0:HH:mm}'}" Classes="ListItemSubtitle"/>
													<TextBlock Text="•" Classes="ListItemSubtitle"/>
													<TextBlock Text="{Binding Item.Quantidade, StringFormat='{}{0} unidades'}" Classes="ListItemSubtitle"/>
												</StackPanel>
											</StackPanel>

											<TextBlock Grid.Column="2" Text="{Binding Item.ValorTotal, StringFormat='{}{0:C}'}" Classes="ListItemValue"/>

										</Grid>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Border>

					<Rectangle Height="20" Fill="Transparent"/>
				</StackPanel>
			</ScrollViewer>
		</Grid>

		<Grid Grid.RowSpan="2" IsVisible="{Binding EditandoData}" Background="#80000000" ZIndex="100">
			<Border Background="{DynamicResource WaSurface}" CornerRadius="12" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
				<StackPanel Spacing="15">
					<TextBlock Text="Selecione o Novo Dia" Classes="HeaderTitle" FontSize="18" HorizontalAlignment="Center"/>
					
					<TextBlock Text="{Binding ItemSendoEditado.Item.Produto.Nome}" 
                               Foreground="{DynamicResource WaTextSecondary}" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,10"/>

					<DatePicker SelectedDate="{Binding NovaDataSelecionada}" 
                                HorizontalAlignment="Stretch" 
                                Background="Transparent" 
                                DayFormat="dd" MonthFormat="MMM" YearFormat="yyyy" />

					<Button Content="Cancelar" 
                            Command="{Binding CancelarEdicaoCommand}" 
                            Margin="0,15,0,0" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center"/>
				</StackPanel>
			</Border>
		</Grid>

	</Grid>
</UserControl>