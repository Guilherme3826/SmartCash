<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="clr-namespace:SmartCash.ViewModels.Categorias"
             x:DataType="vm:CategoriaDetalhesViewModel"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             Background="{DynamicResource WaBackground}"
             x:Class="SmartCash.Views.Categorias.CategoriaDetalhesView">

	<Grid RowDefinitions="Auto, *">

		<Border Grid.Row="0" Classes="HeaderBox" CornerRadius="0"
                x:CompileBindings="False"
                Padding="{Binding $parent[TopLevel].InsetsManager.SafeAreaPadding, FallbackValue='0,40,0,0'}">

			<Border Classes="HeaderContent" Padding="10,12">
				<StackPanel Spacing="15">
					<Grid ColumnDefinitions="Auto, *, Auto">

						<Button Grid.Column="0"
                                Command="{Binding VoltarCommand}"
                                Classes="IconButton"
                                Margin="0,0,5,0">
							<i:Icon Value="fa-solid fa-arrow-left" Foreground="{DynamicResource WaHeaderIcon}" FontSize="24"/>
						</Button>

						<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
							<Border Classes="IconAvatarCard">
								<i:Icon Value="{Binding Categoria.IconeApresentacao, FallbackValue='fa-solid fa-tags'}" Classes="IconAvatarGraphic"/>
							</Border>
							<TextBlock Text="{Binding Categoria.Nome}" Classes="HeaderTitle" VerticalAlignment="Center"/>
						</StackPanel>

						<Rectangle Grid.Column="2" Width="32" Fill="Transparent"/>
					</Grid>

					<StackPanel IsVisible="{Binding !EstaCarregando}" HorizontalAlignment="Center" Spacing="5">
						<TextBlock Text="{Binding TotalGastoNoPeriodo, StringFormat='{}{0:C}'}" Classes="HeaderSummaryValue"/>
						<TextBlock Text="{Binding PeriodoFiltroAtual, StringFormat='{}Filtrado por: {0}'}" Classes="HeaderSummarySubtitle"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Border>

		<Grid Grid.Row="1">

			<ProgressBar IsIndeterminate="True" IsVisible="{Binding EstaCarregando}" Classes="LoadingBar"/>

			<ScrollViewer IsVisible="{Binding !EstaCarregando}">
				<StackPanel Classes="ListArea">

					<Border Classes="ListContainerCard">
						<ListBox ItemsSource="{Binding Itens}"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="vm:CategoriaItemDisplayModel">
									<Border Classes="ListItemBorder">
										<Grid ColumnDefinitions="Auto, *, Auto">

											<Border Grid.Column="0" Classes="IconAvatarCardWarning">
												<i:Icon Value="fa-solid fa-box-open" Classes="IconAvatarGraphicWarning"/>
											</Border>

											<StackPanel Grid.Column="1" Classes="ListItemTextContainer">
												<TextBlock Text="{Binding Item.Produto.Nome}" Classes="ListItemTitle"/>
												
												<StackPanel Orientation="Horizontal" Spacing="5">
													<TextBlock Text="{Binding DataCompra, StringFormat='{}{0:dd/MM/yyyy}'}" Classes="ListItemSubtitle"/>
													<TextBlock Text="•" Classes="ListItemSubtitle"/>
													<TextBlock Text="{Binding Item.Quantidade, StringFormat='{}{0} unidades'}" Classes="ListItemSubtitle"/>
												</StackPanel>
											</StackPanel>

											<TextBlock Grid.Column="2" Text="{Binding Item.ValorTotal, StringFormat='{}{0:C}'}" Classes="ListItemValue"/>

										</Grid>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Border>

					<Rectangle Height="20" Fill="Transparent"/>
				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>